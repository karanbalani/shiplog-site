{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://shiplog.karanbalani.tech/schemas/shiplog.config.schema.json",
  "title": "shiplog config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "collect", "publish"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "default": {},
      "properties": {
        "displayName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "collect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accounts"],
      "properties": {
        "lookbackDays": {
          "type": "integer",
          "minimum": 0,
          "maximum": 90,
          "default": 7
        },
        "accounts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["provider", "accountId"],
            "properties": {
              "provider": {
                "const": "github"
              },
              "accountId": {
                "type": "string",
                "minLength": 1
              },
              "tokenEnv": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
                "default": "GH_RO_CLASSIC_TOKEN"
              },
              "organizationPatTokens": {
                "type": "array",
                "default": [],
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["organizationId", "tokenEnv"],
                  "properties": {
                    "organizationId": {
                      "type": "string",
                      "minLength": 1
                    },
                    "tokenEnv": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
                    }
                  }
                }
              },
              "ignore": {
                "type": "object",
                "additionalProperties": false,
                "default": {
                  "organizations": [],
                  "repositories": []
                },
                "properties": {
                  "organizations": {
                    "type": "array",
                    "default": [],
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "repositories": {
                    "type": "array",
                    "default": [],
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "publish": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targets"],
      "properties": {
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["provider", "repositoryId"],
            "properties": {
              "provider": {
                "const": "github"
              },
              "repositoryId": {
                "type": "string",
                "minLength": 1
              },
              "branch": {
                "type": "string",
                "minLength": 1,
                "default": "main"
              },
              "path": {
                "type": "string",
                "minLength": 1,
                "default": "README.md"
              },
              "tokenEnv": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
                "default": "GH_RW_REPO_TOKEN"
              }
            }
          }
        }
      }
    }
  }
}
