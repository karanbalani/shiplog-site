{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://shiplog.karanbalani.tech/schemas/render.config.schema.json",
  "title": "shiplog target render config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "markdown"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "queries": {
      "type": "object",
      "default": {},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mode", "sql"],
        "properties": {
          "mode": {
            "enum": ["one", "many"]
          },
          "sql": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "markdown": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "level", "text"],
            "properties": {
              "type": {
                "const": "heading"
              },
              "level": {
                "type": "integer",
                "minimum": 1,
                "maximum": 6
              },
              "text": {
                "type": "string"
              },
              "visibleWhen": {
                "$ref": "#/definitions/visibleWhen"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "text"],
            "properties": {
              "type": {
                "const": "paragraph"
              },
              "text": {
                "type": "string"
              },
              "visibleWhen": {
                "$ref": "#/definitions/visibleWhen"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "query", "columns"],
            "properties": {
              "type": {
                "const": "table"
              },
              "query": {
                "type": "string",
                "minLength": 1
              },
              "columns": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["label", "value"],
                  "properties": {
                    "label": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    }
                  }
                }
              },
              "visibleWhen": {
                "$ref": "#/definitions/visibleWhen"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "query", "value"],
            "properties": {
              "type": {
                "const": "list"
              },
              "query": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "type": "string"
              },
              "visibleWhen": {
                "$ref": "#/definitions/visibleWhen"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "query", "template"],
            "properties": {
              "type": {
                "const": "repeat"
              },
              "query": {
                "type": "string",
                "minLength": 1
              },
              "template": {
                "type": "string"
              },
              "separator": {
                "type": "string"
              },
              "visibleWhen": {
                "$ref": "#/definitions/visibleWhen"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "content"],
            "properties": {
              "type": {
                "const": "rawMarkdown"
              },
              "content": {
                "type": "string"
              },
              "visibleWhen": {
                "$ref": "#/definitions/visibleWhen"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type"],
            "properties": {
              "type": {
                "const": "divider"
              },
              "visibleWhen": {
                "$ref": "#/definitions/visibleWhen"
              }
            }
          }
        ]
      }
    }
  },
  "definitions": {
    "visibleWhen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query", "hasRows"],
      "properties": {
        "query": {
          "type": "string",
          "minLength": 1
        },
        "hasRows": {
          "type": "boolean"
        }
      }
    }
  }
}
