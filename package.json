{
  "name": "shiplog-site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run sync:shiplog && astro dev",
    "build": "bun run sync:shiplog && astro check && astro build",
    "preview": "astro preview",
    "check": "bun run sync:shiplog && astro check",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "bun run sync:shiplog && oxlint . --react-plugin --jsx-a11y-plugin --import-plugin --deny-warnings --ignore-pattern dist --ignore-pattern .astro",
    "lint:fix": "bun run sync:shiplog && oxlint . --react-plugin --jsx-a11y-plugin --import-plugin --deny-warnings --ignore-pattern dist --ignore-pattern .astro --fix",
    "test": "bun test",
    "verify": "bun run sync:shiplog && bun run format:check && bun run lint && bun run build",
    "sync:shiplog": "bun scripts/sync_shiplog_assets.ts"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.6",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "ajv": "^8.20.0",
    "astro": "^6.4.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.13"
}
