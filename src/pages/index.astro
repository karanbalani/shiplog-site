---
import '../styles/global.css'
---

<!doctype html>
<html lang="en" class="landing-root" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="shiplog collects GitHub activity into your own Postgres and renders it back into a profile README."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>shiplog - GitHub activity, owned by you</title>
    <script is:inline>
      (() => {
        const storageKey = 'shiplog-landing-theme'
        const modes = ['system', 'light', 'dark']
        const savedMode = localStorage.getItem(storageKey)
        const mode = modes.includes(savedMode) ? savedMode : 'system'
        const theme = window.matchMedia('(prefers-color-scheme: dark)').matches
          ? 'dark'
          : 'light'

        document.documentElement.dataset.themeMode = mode
        document.documentElement.dataset.theme = mode === 'system' ? theme : mode
      })()
    </script>
  </head>
  <body class="landing-page">
    <header class="site-header">
      <a class="brand" href="/" aria-label="shiplog home">
        <span class="brand-mark" aria-hidden="true">sl</span>
        <span>shiplog</span>
      </a>
      <nav class="top-nav" aria-label="Main navigation">
        <a href="/config-builder/">Config Builder</a>
        <a href="https://github.com/karanbalani/shiplog">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Forkable GitHub activity pipeline</p>
          <h1>shiplog</h1>
          <p class="hero-text">
            Daily snapshots of your GitHub activity into your own Postgres,
            rendered back into a profile README.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="https://github.com/karanbalani/shiplog/fork">
              Fork repo
            </a>
            <a class="button button-secondary" href="/config-builder/">Config builder</a>
            <a class="button button-secondary" href="https://github.com/karanbalani/shiplog">
              GitHub
            </a>
          </div>
        </div>
      </section>
    </main>

    <button
      class="theme-toggle"
      type="button"
      aria-label="Theme: system. Click for light theme."
      data-theme-toggle
    >
      <span class="theme-toggle__mark" data-theme-mark aria-hidden="true">S</span>
      <span class="theme-toggle__label" data-theme-label>System</span>
    </button>

    <script>
      const storageKey = 'shiplog-landing-theme'
      const modes = ['system', 'light', 'dark'] as const
      const root = document.documentElement
      const toggle = document.querySelector('[data-theme-toggle]')
      const mark = document.querySelector('[data-theme-mark]')
      const label = document.querySelector('[data-theme-label]')
      const systemPreference = window.matchMedia('(prefers-color-scheme: dark)')

      type ThemeMode = (typeof modes)[number]

      const isThemeMode = (mode: string | undefined): mode is ThemeMode =>
        modes.includes(mode as ThemeMode)

      const resolveTheme = (mode: ThemeMode) =>
        mode === 'system' ? (systemPreference.matches ? 'dark' : 'light') : mode

      const getNextMode = (mode: ThemeMode) =>
        modes[(modes.indexOf(mode) + 1) % modes.length]

      const setThemeMode = (mode: ThemeMode) => {
        const nextMode = getNextMode(mode)
        const modeLabel = mode[0].toUpperCase() + mode.slice(1)

        root.dataset.themeMode = mode
        root.dataset.theme = resolveTheme(mode)
        toggle?.setAttribute(
          'aria-label',
          `Theme: ${mode}. Click for ${nextMode} theme.`,
        )

        if (mark instanceof HTMLElement) {
          mark.textContent = modeLabel[0]
        }

        if (label instanceof HTMLElement) {
          label.textContent = modeLabel
        }
      }

      setThemeMode(isThemeMode(root.dataset.themeMode) ? root.dataset.themeMode : 'system')

      toggle?.addEventListener('click', () => {
        const mode = isThemeMode(root.dataset.themeMode)
          ? getNextMode(root.dataset.themeMode)
          : 'system'

        localStorage.setItem(storageKey, mode)
        setThemeMode(mode)
      })

      systemPreference.addEventListener('change', () => {
        if (root.dataset.themeMode === 'system') {
          setThemeMode('system')
        }
      })
    </script>
  </body>
</html>
