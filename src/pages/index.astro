---
import FontPreload from '../components/FontPreload.astro'
import ThemeInit from '../components/ThemeInit.astro'
import ThemeToggle from '../components/ThemeToggle.astro'
import '../styles/global.css'
---

<!doctype html>
<html lang="en" class="landing-root" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="shiplog collects GitHub activity into your own Postgres and renders it back into a profile README."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <FontPreload />
    <title>shiplog - GitHub activity, owned by you</title>
    <ThemeInit />
  </head>
  <body class="landing-page">
    <header class="site-header">
      <a class="brand" href="/" aria-label="shiplog home">
        <span class="brand-mark" aria-hidden="true">sl</span>
        <span>shiplog</span>
      </a>
      <nav class="top-nav" aria-label="Main navigation">
        <a href="/config-builder/">Config Builder</a>
        <a href="/rendor-studio/">Rendor Studio</a>
        <a href="https://github.com/karanbalani/shiplog">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Forkable GitHub activity pipeline</p>
          <h1>shiplog</h1>
          <p class="hero-text">
            Daily snapshots of your GitHub activity into your own Postgres,
            rendered back into a profile README.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="https://github.com/karanbalani/shiplog/fork">
              Fork repo
            </a>
            <a class="button button-secondary" href="/config-builder/">Config builder</a>
            <a class="button button-secondary" href="/rendor-studio/">Rendor studio</a>
            <a class="button button-secondary" href="https://github.com/karanbalani/shiplog">
              GitHub
            </a>
          </div>
        </div>
      </section>
    </main>

    <ThemeToggle />
  </body>
</html>
